# IDP_GITHUB_CLIENT_ID = ""
# IDP_GITHUB_CLIENT_SECRET = ""
# IDP_GITHUB_SCOPES = "read:user user:email"

# --- Generic OIDC ------------------------------------------------------------
# IDP_OPENID_CONNECT_DISPLAY_NAME = "OpenID Connect"
# IDP_OPENID_CONNECT_KIND = "oidc"
# IDP_OPENID_CONNECT_OIDC_ISSUER_URL = ""
# IDP_OPENID_CONNECT_CLIENT_ID = ""
# IDP_OPENID_CONNECT_CLIENT_SECRET = ""
# IDP_OPENID_CONNECT_SCOPES = "openid profile email"

# ---- sample_app settings (optional verification app) -----------------------

# Set to true to start sample_app.py as an internal verification app (default: false).
# SAMPLE_APP_ENABLED = false

# Internal port for sample_app.py (default: 8081).
# Set APP_UPSTREAM to this value to route traffic through the sample app.
# SAMPLE_APP_PORT = "8081"

# Azure Blob Storage URL for delegated storage access verification.
# Format: https://<account>.blob.core.windows.net/<container>/<blob>
# SAMPLE_APP_STORAGE_BLOB_URL = ""

# OBO scope used when requesting a storage access token (default: https://storage.azure.com/.default).
# SAMPLE_APP_OBO_STORAGE_SCOPE = "https://storage.azure.com/.default"

# Storage request timeout in seconds (default: 10).
# SAMPLE_APP_STORAGE_TIMEOUT_SECONDS = "10"

# Number of bytes to preview from the storage response (default: 4096).
# SAMPLE_APP_STORAGE_PREVIEW_BYTES = "4096"

# Display name and description shown in the sample app UI.
# SAMPLE_APP_TITLE = "Easy Auth verification app"
# SAMPLE_APP_DESCRIPTION = ""
