{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Emulator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/start.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Debug Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        "${env:EASYAUTH_EXTENSION_TEST_PROJECT_DIR}"
      ],
      "outFiles": ["${workspaceFolder}/vscode-extension/out/**/*.js"],
      "preLaunchTask": "build: extension with binary"
    }
  ]
}
